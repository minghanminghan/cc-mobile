# ── Relay server ─────────────────────────────────────────────────────────────

# Port the relay WebSocket + static file server listens on.
PORT=3001

# ── Tailscale (optional) ──────────────────────────────────────────────────────

# Pre-auth key from https://login.tailscale.com/admin/settings/keys
# When set, start.sh boots tailscaled in userspace-networking mode and joins
# your Tailnet on container startup. Leave unset for local dev if Tailscale
# is installed natively on your machine.
TAILSCALE_AUTH_KEY=tskey-auth-1234

# Override the Tailscale SOCKS5 proxy address used to reach 100.x.x.x IPs.
# Defaults to localhost:1055 whenever TAILSCALE_AUTH_KEY is set.
# Only needed if you run tailscaled on a non-standard port.
# TAILSCALE_SOCKS5=localhost:1055

# ── Web frontend (Vite) ───────────────────────────────────────────────────────

# Override the WebSocket relay URL used by the browser client.
# Defaults to the same host/port as the page (correct for production).
# Set this in dev if the relay is on a different host than the Vite dev server.
# VITE_RELAY_URL=ws://192.168.1.x:3001