# ── Relay server ─────────────────────────────────────────────────────────────

# Port the relay WebSocket + static file server listens on.
# PORT=3001

# ── Tailscale (optional) ──────────────────────────────────────────────────────

# SOCKS5 proxy address used to route 100.x.x.x Tailscale IPs.
# Required only when running in Docker with userspace networking (no kernel TUN).
# When Tailscale is installed natively on the relay host, leave this unset.
# TAILSCALE_SOCKS5=localhost:1055

# ── Web frontend (Vite) ───────────────────────────────────────────────────────

# Override the WebSocket relay URL used by the browser client.
# Defaults to the same host/port as the page (correct for production).
# Set this in dev if the relay is on a different host than the Vite dev server.
# VITE_RELAY_URL=ws://192.168.1.x:3001

# Private key
VITE_PRIVATE_KEY=0