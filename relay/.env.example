# -- Websocket Shared Key ------------------------------------------------------

# Shared key between web/ and relay/ for secure websocket authentcation
WSS_AUTH_KEY=0

# -- Web Push (optional) -------------------------------------------------------
# Generate once with: npx web-push generate-vapid-keys
# Leave unset to disable server-side push (in-tab notifications still work).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@mobile-terminal.local

